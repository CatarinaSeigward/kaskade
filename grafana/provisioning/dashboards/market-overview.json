{
  "id": null,
  "uid": "market-overview",
  "title": "Market Overview",
  "description": "Real-time market surveillance dashboard with price tickers, top movers, and aggregate metrics",
  "tags": [
    "kaskade",
    "real-time"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "VWAP by Symbol (Real-Time)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, symbol, vwap AS value FROM market_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Trade Volume by Symbol",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, symbol, volume AS value FROM market_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Aggregate Market Volatility",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT AVG(volatility) AS value FROM market_metrics WHERE window_start >= NOW() - INTERVAL '5 minutes'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          },
          "min": 0,
          "max": 2
        }
      }
    },
    {
      "id": 4,
      "title": "Active Alerts (Last Hour)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM alerts WHERE detected_at >= NOW() - INTERVAL '1 hour'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Alerts by Severity",
      "type": "piechart",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT severity, COUNT(*) AS count FROM alerts WHERE detected_at >= NOW() - INTERVAL '24 hours' GROUP BY severity",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Trades Processed",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(trade_count) AS value FROM market_metrics WHERE window_start >= NOW() - INTERVAL '1 hour'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "title": "Recent Alerts Table",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT detected_at, symbol, alert_type, severity, z_score, message FROM alerts WHERE detected_at >= NOW() - INTERVAL '1 hour' ORDER BY detected_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}