{
  "id": null,
  "uid": "symbol-deep-dive",
  "title": "Symbol Deep Dive",
  "description": "Detailed analysis dashboard for individual symbol metrics with VWAP, volatility bands, RSI, and alert annotations",
  "tags": [
    "kaskade",
    "symbol-analysis"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "symbol",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        },
        "query": "SELECT DISTINCT symbol FROM market_metrics ORDER BY symbol",
        "current": {
          "text": "AAPL",
          "value": "AAPL"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "VWAP Time Series - $symbol",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, vwap AS \"VWAP\", high AS \"High\", low AS \"Low\" FROM market_metrics WHERE symbol = '$symbol' AND $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "pointSize": 3
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "High"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Low"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Current Metrics - $symbol",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT vwap AS \"VWAP\" FROM market_metrics WHERE symbol = '$symbol' ORDER BY window_start DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 3,
      "title": "RSI - $symbol",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT rsi AS \"RSI\" FROM market_metrics WHERE symbol = '$symbol' ORDER BY window_start DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 50
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 4,
      "title": "Volatility - $symbol",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, volatility FROM market_metrics WHERE symbol = '$symbol' AND $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "color": {
            "mode": "continuous-RdYlGr"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "RSI Oscillator - $symbol",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, rsi FROM market_metrics WHERE symbol = '$symbol' AND $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 45
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "thresholdsStyle": {
              "mode": "dashed"
            }
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Trade Volume - $symbol",
      "type": "barchart",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, volume FROM market_metrics WHERE symbol = '$symbol' AND $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80
          },
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Symbol Alerts - $symbol",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT detected_at, alert_type, severity, z_score, message FROM alerts WHERE symbol = '$symbol' AND $__timeFilter(detected_at) ORDER BY detected_at DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}