{
  "id": null,
  "uid": "operational",
  "title": "Operational Dashboard",
  "description": "Pipeline health monitoring: Kafka lag, Spark latency, Redis memory, PostgreSQL connections, end-to-end latency percentiles",
  "tags": [
    "kaskade",
    "ops",
    "monitoring"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Health Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN COUNT(*) > 0 THEN 'Active' ELSE 'Stalled' END AS \"Pipeline Status\" FROM market_metrics WHERE window_start >= NOW() - INTERVAL '2 minutes'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "Active": {
                  "color": "green",
                  "text": "ACTIVE"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "Stalled": {
                  "color": "red",
                  "text": "STALLED"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Events Processed (Last Hour)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, SUM(trade_count) AS \"Events Processed\" FROM market_metrics WHERE $__timeFilter(window_start) GROUP BY window_start ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Symbols Count",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT symbol) AS \"Active Symbols\" FROM market_metrics WHERE window_start >= NOW() - INTERVAL '5 minutes'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Window Size (trades)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(trade_count)) AS \"Avg Trades/Window\" FROM market_metrics WHERE window_start >= NOW() - INTERVAL '5 minutes'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Alert Rate (per minute)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('minute', detected_at) AS time, severity, COUNT(*) AS count FROM alerts WHERE $__timeFilter(detected_at) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Pipeline Latency (Processing Lag)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS time, EXTRACT(EPOCH FROM (created_at - window_end)) AS \"Processing Lag (s)\" FROM market_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Data Freshness (seconds since last update)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT EXTRACT(EPOCH FROM (NOW() - MAX(created_at))) AS \"Staleness (s)\" FROM market_metrics",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 120,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        }
      }
    }
  ]
}