# ============================================================
# Kaskade - Real-Time Market Analytics Engine
# Environment Configuration
# ============================================================

# Kafka Configuration
KAFKA_BROKER_1=kafka-1:9092
KAFKA_BROKER_2=kafka-2:9093
KAFKA_BROKER_3=kafka-3:9094
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Schema Registry
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=financial_analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics_secure_password

# Producer Configuration
PRODUCER_MODE=simulator
SIMULATOR_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA,META,NVDA,JPM,BAC,GS
SIMULATOR_EVENTS_PER_SEC=10000
SIMULATOR_BASE_PRICES={"AAPL":175.0,"GOOGL":140.0,"MSFT":380.0,"AMZN":178.0,"TSLA":245.0,"META":500.0,"NVDA":800.0,"JPM":195.0,"BAC":35.0,"GS":420.0}

# Alpha Vantage API (optional, for live data mode)
ALPHA_VANTAGE_API_KEY=your_api_key_here

# Spark Configuration
SPARK_MASTER=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# Anomaly Detection Thresholds
ANOMALY_PRICE_ZSCORE_THRESHOLD=3.0
ANOMALY_VOLUME_MULTIPLIER=5.0
ANOMALY_VOLATILITY_MULTIPLIER=3.0

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
